# =============================================================================
# outreach-credify — environment variable reference
# =============================================================================
#
# NAMES ONLY. Never commit real values to this file or any other.
#
# ⚠ NOTHING HERE IS USED YET. There is no backend — api() at index.html:1898 is
#   a stub that writes to localStorage. This file documents the variables the
#   Phase 1 server will need. See docs/deployment.md#configuration-reference.
#
# Usage (once a backend exists):
#   cp .env.example .env      # then fill in from the secret manager
#
# RULES
#   1. .env is gitignored. If it ever appears in `git status`, stop and fix it.
#   2. .env must live OUTSIDE any web document root. An .env under htdocs is
#      served over HTTP by Apache. See docs/deployment.md isolation rules.
#   3. Real values live in a secret manager — not a wiki, not Slack, not here.
#   4. The server validates every required var on boot and exits non-zero if one
#      is missing. A server that starts without ESP_WEBHOOK_SECRET and silently
#      accepts unsigned webhooks is worse than one that refuses to start.
#   5. Every vendor credential below maps to a signed BAA. If you cannot name
#      the BAA covering a vendor, it must not see production traffic.
#      See docs/adr/0007-baa-gated-vendor-selection.md.
# =============================================================================


# --- Core -------------------------------------------------------------------
NODE_ENV=
PORT=
# Public base URL. Used to build unsubscribe and portal links.
APP_BASE_URL=


# --- Database ---------------------------------------------------------------
# Postgres connection string. Never a public host — the DB has no public IP.
DATABASE_URL=
# Require TLS to the database. Must be true in production.
DATABASE_SSL=
DATABASE_POOL_MAX=


# --- Sessions ---------------------------------------------------------------
# Rotating this invalidates every active session (a forced logout for everyone).
# That is a feature — it is how you revoke access instantly. Announce first.
SESSION_SECRET=
# Shared clinic workstations are normal. Keep the idle timeout short.
SESSION_IDLE_TIMEOUT_MIN=
SESSION_ABSOLUTE_TIMEOUT_H=


# --- Encryption -------------------------------------------------------------
# Managed KMS. NEVER put a raw encryption key in an env var.
# Protects contact_field_values.value where form_fields.is_phi = true.
KMS_KEY_ID=
KMS_REGION=


# --- Email provider (ESP) ---------------------------------------------------
# ⚠ BAA REQUIRED — this vendor transmits message bodies.
ESP_PROVIDER=
ESP_API_KEY=
# Verifies inbound webhook signatures. Without it, anyone can forge a bounce
# event and suppress an address — or forge an open and corrupt your reporting.
ESP_WEBHOOK_SECRET=
# Sending domain. Needs SPF/DKIM/DMARC configured and passing.
ESP_FROM_DOMAIN=


# --- SMS provider -----------------------------------------------------------
# ⚠ BAA REQUIRED.
# Note: if STOP processing is down, opt-outs are not recorded and the next send
# reaches people who opted out. An SMS vendor outage is a CONSENT incident.
# See docs/operations-runbook.md#service-map.
SMS_PROVIDER=
SMS_API_KEY=
SMS_WEBHOOK_SECRET=
SMS_FROM_NUMBER=


# --- Queue ------------------------------------------------------------------
# Durable queue for scheduled sends and outbound delivery.
# Exactly-once delivery is a correctness requirement, not a scaling one.
QUEUE_URL=
# Keep at or below the ESP's rate limit. The vendor sets the pace.
QUEUE_CONCURRENCY=


# --- Links and tracking -----------------------------------------------------
# ⚠ Signs unsubscribe tokens. Unsubscribe links live in inboxes FOREVER.
#   Rotating this breaks every link ever sent — meaning someone who tries to
#   opt out silently fails to, which is a CAN-SPAM problem and a trust problem.
#   If it must rotate, keep verifying the old secret indefinitely.
UNSUBSCRIBE_TOKEN_SECRET=
# Base URL for open/click tracking redirects.
TRACKING_BASE_URL=


# --- Observability ----------------------------------------------------------
# ⚠ EVERY vendor here sees request data. Each needs a BAA, or must be
#   architecturally incapable of receiving PHI. Logs never contain PHI —
#   see docs/security-compliance.md#logging.
LOG_LEVEL=
SENTRY_DSN=


# --- Feature flags ----------------------------------------------------------
# ⚠ THE KILL SWITCH. Halts ALL outbound sending immediately.
#   Defaults to OFF in every environment — including production — until the
#   go-live checklist passes: docs/security-compliance.md#go-live-checklist.
#   First move in any send-related incident: set this to false.
FEATURE_SENDING_ENABLED=
FEATURE_SMS_ENABLED=
